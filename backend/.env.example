# ── Required ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Auth (Clerk — https://dashboard.clerk.com) ────────────
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...

# ── Billing (Stripe — https://dashboard.stripe.com) ───────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...    # $12/month — 20 rooms
STRIPE_PRICE_PRO=price_...        # $24/month — unlimited

# ── Deployment ────────────────────────────────────────────
APP_URL=https://yourapp.com
ALLOWED_ORIGINS=https://yourapp.com,http://localhost:5173
PORT=3001

# ── Database (optional — defaults to furnish.db in repo root) ─
# DATABASE_URL=sqlite:/path/to/furnish.db

# ── Scrapers (optional) ───────────────────────────────────
# PROXY_URL=http://user:pass@proxy:port   # Residential proxy for Mercari if CF blocks
