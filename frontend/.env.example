# Clerk frontend key (from https://dashboard.clerk.com → API Keys)
# Without this, auth is disabled (dev mode)
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...

# Backend API URL — in dev, Vite proxies /api so you can leave this blank
# In production, set this to your deployed backend URL
# VITE_API_URL=https://api.yourapp.com
